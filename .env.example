# NixBall server configuration. Copy to `.env` for local dev (it is gitignored).
# On the server, set these via systemd `Environment=` lines instead.
#
# Payments + accounts are OPTIONAL: if DATABASE_URL / SESSION_SECRET / the
# Stripe keys are absent, the game runs normally and premium effects fall back
# to local preview-unlocks. Set all of them to enable real purchases.

# Public origin the browser uses — for magic-link URLs and Stripe redirects.
PUBLIC_BASE_URL=http://localhost:3000

# Postgres connection string. Recommended: a dedicated `nixball` database in
# your existing Postgres instance.
DATABASE_URL=postgres://nixball:CHANGE_ME@localhost:5432/nixball

# Random secret used to sign session cookies. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Stripe — use TEST keys until you're ready to go live.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# From `stripe listen` (dev) or the Dashboard webhook endpoint (prod).
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Email delivery for magic links: "console" (logs the link to the server log,
# good for dev) or "resend" (set RESEND_API_KEY + MAIL_FROM).
MAIL_TRANSPORT=console
RESEND_API_KEY=
MAIL_FROM=NixBall <login@nixball.example.com>
