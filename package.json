{
  "name": "nixball",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -k -n srv,web -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch src/server/main.ts",
    "dev:client": "vite",
    "build": "vite build && npm run build:server",
    "build:server": "esbuild src/server/main.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/server.cjs --external:bufferutil --external:utf-8-validate --external:pg-native",
    "start": "node dist/server.cjs",
    "typecheck": "tsc --noEmit",
    "test": "tsx scripts/test-physics.ts",
    "smoke": "node scripts/smoke.mjs"
  },
  "dependencies": {
    "pg": "^8.13.1",
    "stripe": "^17.5.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "@types/ws": "^8.5.13",
    "concurrently": "^9.1.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
